{
  "name": "apidocgen",
  "version": "0.1.0",
  "type": "module",
  "description": "ApiDocGen CLI — sync your OpenAPI spec with ApiDocGen and generate AI-powered API documentation",
  "keywords": [
    "openapi",
    "swagger",
    "documentation",
    "api-docs",
    "ai",
    "cli"
  ],
  "author": "Freddy Arcia <fgarcia@capitalgurus.com>",
  "license": "MIT",
  "homepage": "https://github.com/Capital-Gurus/apidocgen-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Capital-Gurus/apidocgen-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Capital-Gurus/apidocgen-cli/issues"
  },
  "bin": {
    "apidocgen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.0",
    "ora": "^9.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  }
}
